# --- BACKEND SETTINGS ---
# Your Google Gemini API Key from https://aistudio.google.com/app/apikey (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Secret key for JWT authentication (Required for production)
# Generate a secure one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your_secure_jwt_secret_here

# --- FRONTEND SETTINGS ---
# The URL where your backend is running (Required)
# Local development: http://127.0.0.1:8000
# Production: Your deployed backend URL
 NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
